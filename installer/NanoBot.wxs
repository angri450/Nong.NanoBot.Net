<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="NanoBot.net"
    Manufacturer="Angri450"
    Version="$(var.ProductVersion)"
    UpgradeCode="{2D736C6F-6E63-6F64-652D-4E616E6F426F}"
    Scope="perUser">
    <SummaryInformation Description="NanoBot.net GroundPA runtime" Manufacturer="Angri450" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of NanoBot.net is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="NanoBot.net" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="NanoBot.net" />
    </StandardDirectory>

    <Component Id="StartMenuShortcuts" Directory="ApplicationProgramsFolder" Guid="{8E4E1E0B-0A21-47F1-92AF-8A29E65D80B6}">
      <Shortcut
        Id="StartWebUiShortcut"
        Name="NanoBot WebUI"
        Target="[INSTALLFOLDER]nanobot.exe"
        Arguments="web"
        WorkingDirectory="INSTALLFOLDER"
        Advertise="no" />
      <Shortcut
        Id="ShowCliHelpShortcut"
        Name="NanoBot CLI Help"
        Target="[INSTALLFOLDER]nanobot.exe"
        Arguments="--help"
        WorkingDirectory="INSTALLFOLDER"
        Advertise="no" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\Angri450\NanoBot.net"
        Name="StartMenuShortcuts"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>

    <Component Id="UserPathEnvironment" Directory="INSTALLFOLDER" Guid="{C30C0B44-7E43-4886-9002-C93B0FC63E31}">
      <Environment
        Id="AddNanobotToUserPath"
        Name="PATH"
        Value="[INSTALLFOLDER]"
        Permanent="no"
        Part="last"
        Action="set"
        System="no" />
      <RegistryValue
        Root="HKCU"
        Key="Software\Angri450\NanoBot.net"
        Name="InstallDir"
        Type="string"
        Value="[INSTALLFOLDER]"
        KeyPath="yes" />
    </Component>

    <Feature Id="MainFeature" Title="NanoBot.net" Level="1">
      <ComponentGroupRef Id="PublishedFiles" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="UserPathEnvironment" />
    </Feature>
  </Package>
</Wix>
